rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Mengizinkan semua akses baca dan tulis agar aplikasi fakhricoffee bisa CRUD kembali.
      // Catatan: Ini adalah mode "Test Mode" standar dari Firebase.
      allow read, write: if true;
    }
  }
}
